# ============================================================
# MCP Hub Configuration
# Copy this file to config/.env and fill in your values.
# NEVER commit config/.env to git — it contains secrets.
# ============================================================

# ── UCM6308 Phone System ─────────────────────────────────────
UCM_HOST=192.168.1.x          # LAN IP or your static BT IP
UCM_PORT=8089                  # 8089=HTTPS (default), 80=HTTP
UCM_USER=admin
UCM_PASS=your_admin_password
UCM_HTTPS=true

# ── Companies House (free API key) ───────────────────────────
# Register at: https://developer.company-information.service.gov.uk/manage-applications
COMPANIES_HOUSE_API_KEY=

# ── HMRC Making Tax Digital ──────────────────────────────────
# Register at: https://developer.service.hmrc.gov.uk/developer/applications
HMRC_CLIENT_ID=
HMRC_CLIENT_SECRET=
HMRC_ACCESS_TOKEN=             # OAuth2 Bearer token
HMRC_AGENT_ARN=                # Agent Reference Number (from HMRC Agent Services Account)
HMRC_SANDBOX=false             # Set to true for testing

# ── Employment Hero / KeyPay UK ──────────────────────────────
# Get API key from: Employment Hero > Settings > API Access
KEYPAY_API_KEY=
KEYPAY_BUSINESS_ID=

# ── Xero (all products) ──────────────────────────────────────
# Handled by @xeroapi/xero-mcp-server — configure separately
# See: mcp-hub/xero/README.md
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# ── ElevenLabs ───────────────────────────────────────────────
# Get from: https://elevenlabs.io/app/settings/api-keys
# Free tier: 10,000 credits/month
ELEVENLABS_API_KEY=

# ── Syft Analytics ───────────────────────────────────────────
SYFT_API_KEY=

# ── Adfin ─────────────────────────────────────────────────────
ADFIN_API_KEY=

# ── Inform Direct ─────────────────────────────────────────────
INFORM_DIRECT_API_KEY=

# ── One Gateways ─────────────────────────────────────────────
ONE_GATEWAYS_API_KEY=
ONE_GATEWAYS_MERCHANT_ID=
ONE_GATEWAYS_SANDBOX=false
